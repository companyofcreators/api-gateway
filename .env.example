# Environment: dev | prod
ENV=dev

# HTTP server
HTTP_ADDRESS=:8080

# Redis (for rate limiting)
REDIS_ADDRESS=localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# JWT public key path (RSA PEM file)
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Internal service URLs
AUTH_SERVICE_URL=http://auth-service:8081
USER_SERVICE_URL=http://user-service:8082
ORDER_SERVICE_URL=http://order-service:8083
OFFER_SERVICE_URL=http://offer-service:8084
CHAT_SERVICE_URL=http://chat-service:8085
FILE_SERVICE_URL=http://file-service:8086
NOTIFICATION_SERVICE_URL=http://notification-service:8087
