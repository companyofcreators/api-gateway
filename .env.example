# Environment: dev | prod
ENV=dev

# HTTP server
HTTP_ADDRESS=:8080

# Redis (for rate limiting)
REDIS_ADDRESS=localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate limiting
RATE_LIMIT_LIMIT=300
RATE_LIMIT_WINDOW_SECONDS=60

# JWT public key path (RSA PEM file)
JWT_PUBLIC_KEY_PATH=../keys/public.pem

# Must match every backend service.
HEADER_HMAC_KEY=diploma-internal-hmac-secret-key-2026

# Internal service URLs
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
ORDER_SERVICE_URL=http://localhost:8083
OFFER_SERVICE_URL=http://localhost:8084
CHAT_SERVICE_URL=http://localhost:8085
FILE_SERVICE_URL=http://localhost:8086
NOTIFICATION_SERVICE_URL=http://localhost:8087
